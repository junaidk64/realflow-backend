PORT=5000
MONGODB_URI=mongodb://localhost:27017/email-auto
JWT_SECRET=your-jwt-secret-here-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-here-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback
REDIS_URL=redis://localhost:6379
N8N_BASE_URL=https://n8n.boldme.site
N8N_API_KEY=your-n8n-api-key
ENCRYPTION_KEY=32-char-encryption-key-here-xxxx
FRONTEND_URL=http://localhost:3000
RESEND_API_KEY=your-resend-api-key
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
NODE_ENV=development
GOOGLE_PUBSUB_TOPIC=projects/your-project/topics/gmail-push
